<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Thème sombre — remplace les brushes dynamiques de Styles.xaml -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#252525"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E3E"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#3E3E3E"/>
    <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#1A1A1A"/>

</ResourceDictionary>
