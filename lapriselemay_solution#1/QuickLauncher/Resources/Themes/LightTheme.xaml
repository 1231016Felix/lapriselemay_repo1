<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Thème clair — remplace les brushes dynamiques de Styles.xaml -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#999999"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="CodeBackgroundBrush" Color="#F8F8F8"/>

</ResourceDictionary>
